DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-app.up.railway.app,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
DJANGO_SECURE_SSL_REDIRECT=True

# Railway provides this in the Postgres service; replace with the real value.
DATABASE_URL=postgresql://user:password@host:port/dbname

# Optional: require SSL for DB connections if needed.
DJANGO_DB_SSL_REQUIRE=True

# Media uploads (admin photo upload)
# Option A: Railway Volume (set to the mount path you configured)
DJANGO_MEDIA_ROOT=/data/media

# Option B: S3-compatible storage
DJANGO_USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
